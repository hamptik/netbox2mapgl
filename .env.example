# NetBox source
NETBOX_URL=https://netbox.example.com
NETBOX_TOKEN=change-me

# SQLite cache (persisted in the /data volume inside the container)
DB_PATH=/data/netbox_cache.db

# App
APP_PORT=5000

# Runtime tuning
NETBOX_VERIFY_SSL=true
NETBOX_PAGE_SIZE=1000
CACHE_INTERVAL_SEC=1200
TRACE_CONCURRENCY=1
LOG_LEVEL=INFO
BLANK_LINES_BETWEEN_OBJECTS=3

# NetBox domain configuration
NETBOX_MAIN_TAG=mapgl-main
NETBOX_TARGET_ROLES=["router","switch"]
NETBOX_LAT_FIELD=lat
NETBOX_LON_FIELD=lon
